{
  "name": "TinyTuya Scanner",
  "version": "1.1.6",
  "slug": "tuya_scanner",
  "description": "TinyTuya Scanner is a UI wrapper for the TinyTuya library created by jasonacox. The scanner and key retrieval mechanism was built by the TinyTuya team — this addon only provides a friendly web interface for Home Assistant.",
  "url": "https://github.com/Adam7411/tuya_scanner",
  "arch": [
    "aarch64",
    "amd64",
    "armhf",
    "armv7",
    "i386"
  ],
  "startup": "application",
  "boot": "auto",
  "init": false,
  "ports": {
    "7080/tcp": 7080
  },
  "ports_description": {
    "7080/tcp": "Panel webowy"
  },
  "host_network": true,
  "options": {
    "scan_interval": 3600,
    "scan_duration": 18
  },
  "schema": {
    "scan_interval": "int(60,86400)",
    "scan_duration": "int(5,60)"
  },
  "panel_icon": "mdi:radar",
  "panel_title": "Tuya Scanner",
  "ingress": true,
  "ingress_port": 7080,
  "homeassistant_api": false,
  "hassio_api": false,
  "map": [
    "data:rw"
  ]
}
